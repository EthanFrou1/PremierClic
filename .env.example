# Example environment variables (DO NOT COMMIT real secrets)

# Postgres
POSTGRES_USER=premierclic
POSTGRES_PASSWORD=change_me
POSTGRES_DB=premierclic
DATABASE_URL=Host=db;Port=5432;Database=premierclic;Username=premierclic;Password=change_me

# JWT
JWT_SECRET=replace_with_a_strong_random_value

# SMTP (for Step 6)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=supersecret

# Frontend
VITE_API_BASE_URL=http://localhost:5000
VITE_GOOGLE_MAPS_API_KEY=replace_with_a_referrer_restricted_google_maps_key

GOOGLE_PLACES_API_KEY=replace_with_an_ip_restricted_google_places_key

# Netlify (deploiement automatique des maquettes prospects)
NETLIFY_API_TOKEN=replace_with_a_netlify_personal_access_token
NETLIFY_SITE_ID=replace_with_your_netlify_site_id

# Liens inclus dans les prompts de message de prospection (preuve sociale / grille tarifaire)
COMPANY_WEBSITE_URL=https://votre-site.example.com
PRICING_PAGE_URL=https://votre-page-tarifs.example.com